const { SlashCommandBuilder, EmbedBuilder, ButtonBuilder, ButtonStyle, ActionRowBuilder, PermissionFlagsBits } = require("discord.js");
const path = require("path");
const fs = require("fs").promises;
const storage = require("../../services/storage");
const logger = require("../../utils/logger");
const debug = require("../../utils/debug");

function safeLabel(text) {
  const s = String(text || "").trim();
  return s.length > 80 ? s.slice(0, 77) + "..." : s;
}

async function getNextReactionName() {
  const index = await storage.loadJson("reactionIndex").catch(() => ({}));
  const current = Number(index?.last || 0);
  return { next: current + 1, current };
}

async function saveNextReactionIndex(next) {
  await storage.saveJson("reactionIndex", { last: next });
}

async function loadAllReactions() {
  const index = await storage.loadJson("reactionIndex").catch(() => ({}));
  const last = Number(index?.last || 0);
  const items = [];

  for (let i = 1; i <= last; i++) {
    const data = await storage.loadJson(`reaction${i}`).catch(() => null);
    if (data && data.message_id && data.role_id) {
      items.push({ id: i, ...data });
    }
  }

  return items;
}

module.exports = {
  data: new SlashCommandBuilder()
    .setName("reactionrolecreate")
    .setDescription("Create a reaction-role button message")
    .setDefaultMemberPermissions(PermissionFlagsBits.Administrator)
    .addStringOption(option =>
      option
        .setName("message")
        .setDescription("Text to use as the embed title and button label")
        .setRequired(true)
    )
    .addRoleOption(option =>
      option
        .setName("role")
        .setDescription("Role to give when the button is clicked")
        .setRequired(true)
    ),

  async execute(interaction) {
    try {
      if (!interaction.memberPermissions?.has(PermissionFlagsBits.Administrator)) {
        return interaction.reply({
          content: "You must be an administrator to use this command.",
          ephemeral: true
        });
      }

      const message = interaction.options.getString("message", true).trim();
      const role = interaction.options.getRole("role", true);

      if (!message) {
        return interaction.reply({
          content: "Message cannot be empty.",
          ephemeral: true
        });
      }

      const indexData = await storage.loadJson("reactionIndex").catch(() => ({ last: 0 }));
      const nextId = Number(indexData?.last || 0) + 1;
      const fileKey = `reaction${nextId}`;

      const embed = new EmbedBuilder()
        .setTitle(message)
        .setColor(0x2ecc71);

      const button = new ButtonBuilder()
        .setCustomId(`reactionrole:${nextId}`)
        .setLabel(safeLabel(message))
        .setStyle(ButtonStyle.Primary);

      const row = new ActionRowBuilder().addComponents(button);

      const sent = await interaction.reply({
        embeds: [embed],
        components: [row],
        fetchReply: true
      });

      const data = {
        id: nextId,
        guild_id: interaction.guildId,
        channel_id: interaction.channelId,
        message_id: sent.id,
        role_id: role.id,
        role_name: role.name,
        label: message,
        created_by: interaction.user.id,
        created_at: new Date().toISOString()
      };

      await storage.saveJson(fileKey, data);
      await storage.saveJson("reactionIndex", { last: nextId });

      const ok = await interaction.followUp({
        content: `✅ Reaction role created and saved as **${fileKey}.json**.`,
        ephemeral: true
      });

      setTimeout(() => {
        ok.delete().catch(() => {});
      }, 5000);
    } catch (err) {
      logger.error("reactionrolecreate error", err);
      debug.fail("reactionrolecreate", err, { user: interaction.user?.tag });
      return interaction.reply({
        content: `❌ Failed to create reaction role: ${err.message || "Unknown error"}`,
        ephemeral: true
      }).catch(() => {});
    }
  }
};
